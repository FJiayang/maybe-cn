<%# locals: (import:) %>

<%= styled_form_with model: @import, url: import_configuration_path(@import), scope: :import, method: :patch, class: "space-y-4" do |form| %>
  <%= form.select :entity_type_col_label, import.csv_headers, { include_blank: t(".leave_empty"), label: t(".entity_type") } %>
  <%= form.select :name_col_label, import.csv_headers, { include_blank: t(".leave_empty"), label: t("common.labels.name") }, required: true %>
  <%= form.select :amount_col_label, import.csv_headers, { include_blank: t(".leave_empty"), label: t("common.labels.balance") }, required: true %>
  <%= form.select :currency_col_label, import.csv_headers, { include_blank: "Default", label: t("common.labels.currency") } %>

  <%= form.submit "Apply configuration", disabled: import.complete? %>
<% end %>
